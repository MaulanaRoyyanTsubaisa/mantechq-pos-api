+              <td><input type="checkbox" /></td>
+              <td className="mono fw-600">{item.no}</td>
+              <td>{item.pelanggan}</td>
+              <td>{item.outlet}</td>
+              <td>{item.tgl}</td>
+              {type === 'pengiriman' ? <td className="mono text-muted">{item.berlaku}</td> : <td className={item.status === 'Terlambat' ? 'text-danger' : ''}>{item.berlaku}</td>}
+              {type === 'invoice' ? <td className="fw-600">{item.total}</td> : null}
+              {type === 'invoice' ? <td className={item.status === 'Belum Lunas' ? 'text-danger fw-700' : 'text-muted'}>{item.sisa}</td> : <td className="fw-600">{item.total}</td>}
+              <td><StatusBadge status={item.status} /></td>
+              <td><button className="row-more"><MoreVertical size={15} /></button></td>
+            </tr>
