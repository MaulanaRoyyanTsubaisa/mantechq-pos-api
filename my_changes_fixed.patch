+
+  const filtered = config.demo.filter((item) => {
+    const q = query.toLowerCase()
+    const matchQ = !q || item.no.toLowerCase().includes(q) || item.pelanggan.toLowerCase().includes(q)
+    const matchStatus = statusTab === 'Semua' || item.status === statusTab
+    return matchQ && matchStatus
+  })
+
+  const kpiCards = config.kpiLabels.map((label, i) => {
+    const counts = [config.demo.length, config.demo.filter((d) => d.status === config.statuses[1]).length,
+      config.demo.filter((d) => d.status === config.statuses[2]).length, config.demo.filter((d) => d.status === config.statuses[3]).length]
+    const tones = ['blue', 'yellow', 'green', 'red']
+    return [label, counts[i] ?? 0, tones[i]]
+  })
+
+  return (
+    <main className="content inv-page">
+      <CapitalBanner compact />
+      <section className="panel inv-card">
+        <PageHeader
+          title={config.title}
+          icon={FileText}
+          favorite={favorite}
+          onFavorite={() => setFavorite((v) => !v)}
+          onHelp={() => toast.info(`Bantuan ${config.title}`)}
+          actions={[
+            <Button key="exp" variant="outline" onClick={() => toast.success('Ekspor')}><Download size={15} /> Ekspor</Button>,
+            <Button key="add" onClick={() => setPanelOpen(true)}><Plus size={15} /> {config.addLabel}</Button>,
+          ]}
+        />
+        <KpiStrip cards={kpiCards} />
+        {config.summary ? (
+          <div className="invoice-summary">
+            {config.summary.map(([label, value]) => <MiniKpi key={label} label={label} value={value} />)}
+          </div>
+        ) : null}
+        <FilterBar>
+          <SearchInput value={query} onChange={setQuery} placeholder={`Cari no., pelanggan ...`} />
+          <DateRangePicker open={calendarOpen} range={range} onToggle={() => setCalendarOpen((v) => !v)} onProcess={processRange} onCancel={() => setCalendarOpen(false)} />
+          <SelectButton label="Semua Outlet" />
+          <StatusTabs tabs={config.statuses} active={statusTab} onChange={setStatusTab} />
+        </FilterBar>
+        <DataTable
+          columns={config.columns}
+          rows={filtered}
+          emptyText={`Belum ada ${config.title.toLowerCase()}.`}
